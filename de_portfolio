<script>
  function showCertificate(pdfUrl) {
    document.getElementById('certEmbed').src = pdfUrl;
    document.getElementById('certModal').style.display = 'flex';
  }
  
  function closeModal(event) {
    if (!event || event.target === document.getElementById('certModal')) {
      document.getElementById('certModal').style.display = 'none';
      document.getElementById('certEmbed').src = '';
    }
  }

  (function(){
    "use strict";

    const phrases = [
      "ETL/ELT · Medallion · Automation",
      "from loan officer to data engineer",
      "building reliable data foundations",
      "Snowflake · Databricks · Airflow"
    ];
    let phraseIdx = 0, charIdx = 0, isDeleting = false;
    const el = document.getElementById('typewriter');
    function typeEffect() {
      const full = phrases[phraseIdx];
      if (isDeleting) {
        el.textContent = full.substring(0, charIdx-1);
        charIdx--;
      } else {
        el.textContent = full.substring(0, charIdx+1);
        charIdx++;
      }
      if (!isDeleting && charIdx === full.length) {
        isDeleting = true;
        setTimeout(typeEffect, 1800);
        return;
      }
      if (isDeleting && charIdx === 0) {
        isDeleting = false;
        phraseIdx = (phraseIdx + 1) % phrases.length;
        setTimeout(typeEffect, 300);
        return;
      }
      setTimeout(typeEffect, isDeleting ? 45 : 90);
    }
    typeEffect();

    const canvas = document.getElementById('dataCanvas');
    const ctx = canvas.getContext('2d');
    let width, height;
    let particles = [];
    
    function initCanvas() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
      
      const count = Math.floor((width * height) / 10000);
      particles = [];
      for (let i=0; i<count; i++) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 0.45,
          vy: (Math.random() - 0.1) * 0.5 + 0.2,
          size: Math.random() * 2.5 + 1,
          opacity: Math.random() * 0.25 + 0.15
        });
      }
    }
    
    function drawParticles() {
      ctx.clearRect(0, 0, width, height);
      ctx.fillStyle = '#8bb5d9';
      
      for (let p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        
        if (p.x < 0) p.x = width;
        if (p.x > width) p.x = 0;
        if (p.y < 0) p.y = height;
        if (p.y > height) p.y = 0;
        
        ctx.globalAlpha = p.opacity * 0.7;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI*2);
        ctx.fill();
        
        for (let q of particles) {
          const dx = p.x - q.x;
          const dy = p.y - q.y;
          const dist = Math.sqrt(dx*dx + dy*dy);
          if (dist < 50) {
            ctx.globalAlpha = 0.07 * (1 - dist/50);
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.strokeStyle = '#5e96c2';
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(drawParticles);
    }
    
    window.addEventListener('resize', initCanvas);
    initCanvas();
    drawParticles();

    function drawRing(canvas, percent) {
      const ctx = canvas.getContext('2d');
      const w = 72, h = 72;
      canvas.width = w; canvas.height = h;
      const centerX = w/2, centerY = h/2;
      const radius = 29;
      const startAngle = -0.5 * Math.PI;
      const endAngle = startAngle + (2 * Math.PI * percent/100);
      
      ctx.clearRect(0,0,w,h);
      ctx.beginPath();
      ctx.arc(centerX, centerY, radius, 0, 2*Math.PI);
      ctx.strokeStyle = '#d2e3f5';
      ctx.lineWidth = 5;
      ctx.stroke();
      
      ctx.beginPath();
      ctx.arc(centerX, centerY, radius, startAngle, endAngle);
      ctx.strokeStyle = '#1e6b9b';
      ctx.lineWidth = 5;
      ctx.lineCap = 'round';
      ctx.stroke();
      
      ctx.font = '500 13px "JetBrains Mono", monospace';
      ctx.fillStyle = '#1e4b6e';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(percent+'%', centerX, centerY);
    }
    
    document.querySelectorAll('.ringCanvas').forEach(c => {
      const percent = c.getAttribute('data-percent') || 90;
      drawRing(c, percent);
    });
  })();
</script>
